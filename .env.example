# Auth.js v5
# AUTH_SECRET: generate with `openssl rand -base64 48`. Min 32 chars.
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# AUTH_TRUST_HOST=true   # uncomment when deploying outside Vercel

# Database (Postgres / Neon)
DATABASE_URL=postgres://user:pass@host:5432/webmundial

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
