# Auth.js v5
# AUTH_SECRET: generate with `openssl rand -base64 48`. Min 32 chars.
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# En dev (NODE_ENV != production) trustHost se activa solo. En producción,
# poner AUTH_TRUST_HOST=true cuando despliegues fuera de Vercel.
# AUTH_TRUST_HOST=true

# Database (Postgres / Neon)
DATABASE_URL=postgres://user:pass@host:5432/webmundial

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API-Football (api-sports.io) — primary match-data provider
# Sign up at https://dashboard.api-football.com/register. Free tier:
# 100 req/day, seasons 2022-2024 (suficiente para integration tests
# contra Qatar 2022). Plan Pro $19/mes para WC 2026 en producción.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
