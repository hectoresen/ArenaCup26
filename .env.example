# =======================================================================
# WebMundial 26 — environment variables
# -----------------------------------------------------------------------
# Copia este archivo a `.env` y rellena solo lo que necesites. La app
# arranca con SOLO los bloques "Required" rellenos; el resto son opt-in
# (su ausencia degrada la feature correspondiente a noop, no rompe nada).
# Detalles operativos en `docs/security.md`.
# =======================================================================

# ─── Required (sin esto, la app no arranca) ────────────────────────────

# Auth.js v5. Generar con `openssl rand -base64 48`. Min 32 chars.
AUTH_SECRET=

# Google OAuth. Crear en https://console.cloud.google.com/apis/credentials.
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Postgres. Local: `postgres://postgres:postgres@localhost:5432/wmundial`.
# Producción: connection string completa de Railway/Neon/Supabase.
DATABASE_URL=postgres://user:pass@host:5432/webmundial

# URL pública de la app. Default localhost:3000 para dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Auth.js: opcional ─────────────────────────────────────────────────

# En dev (NODE_ENV != production) trustHost se activa solo. En producción
# fuera de Vercel, poner a true.
# AUTH_TRUST_HOST=true


# ─── Match data (api-football) ─────────────────────────────────────────

# Sign up en https://dashboard.api-football.com/register.
# Sin la key, los crons de sync devuelven 500 `provider_not_configured`
# pero la app sigue funcionando (sin partidos sincronizados, claro).
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Modo de sync. `date-window` (default) usa ventana de fechas;
# `season` filtra por liga+temporada (solo plan pago).
MATCH_DATA_MODE=date-window

# Para date-window: cuántos días antes/después de hoy. El free tier
# acepta ~±1 día.
MATCH_DATA_BEFORE_DAYS=1
MATCH_DATA_AFTER_DAYS=1

# Filtro local de ligas en date-window (CSV de IDs api-football).
# Vacío = todas las ligas que aparezcan en el rango.
# Ej.: "140,253,71" para La Liga, MLS y Brasileirão.
MATCH_DATA_LEAGUE_FILTER=

# Para mode=season (también default para no romper docs):
MATCH_DATA_LEAGUE_ID=1
MATCH_DATA_SEASON=2026


# ─── Cron / sync-fixtures ──────────────────────────────────────────────

# REQUIRED en producción, opcional en dev (rate-limit por IP solo si
# secret válido). GitHub Action lo manda como `Authorization: Bearer
# <secret>`. Generar con `openssl rand -base64 48`. Min 32 chars en prod.
CRON_SECRET=


# ─── Rate limiting (Upstash Redis) ──────────────────────────────────────

# Opcional. Sin esto, los limiters caen a modo noop (todo pasa). El módulo
# emite warning al arrancar en producción para que no pase desapercibido.
# Crear bucket gratis en https://console.upstash.com/.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ─── Error monitoring (Sentry) ──────────────────────────────────────────

# Opcional. Sin DSN, `@sentry/nextjs` queda en noop.
# AUTH_TOKEN solo se usa durante build para subir sourcemaps.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_AUTH_TOKEN=


# ─── Product analytics (Plausible) ─────────────────────────────────────

# Opcional. Sin dominio, el script no se inyecta. Privacy-friendly,
# sin cookies → no requiere banner GDPR.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Por si self-host de Plausible (sino default a plausible.io):
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=


# ─── Web Push notifications ────────────────────────────────────────────

# Opcional. Las tres juntas activan push end-to-end; ausentes → noop.
# Generar par de claves (una vez):
#   npx web-push generate-vapid-keys --json
# Detalle completo en `docs/security.md §9.5`.

# Pública: viaja al cliente para que el browser se suscriba.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Privada: secret. Firma cada push enviado. NO commitear.
VAPID_PRIVATE_KEY=
# Contacto para los push providers (FCM/Mozilla/Apple) si detectan
# abuso. Debe ser `mailto:<email>` o `https:<url>`. Usar el correo
# de soporte público — NO un correo personal.
VAPID_SUBJECT=
